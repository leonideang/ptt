#!/bin/bash
# PTT — Push-to-Talk Transcription launcher
# This script finds or installs uv, then runs ptt.py

DIR="$(cd "$(dirname "$0")/../Resources" && pwd)"

# Find uv
UV=""
for p in "$HOME/.local/bin/uv" "$HOME/.cargo/bin/uv" "/opt/homebrew/bin/uv" "/usr/local/bin/uv"; do
    [ -x "$p" ] && UV="$p" && break
done
[ -z "$UV" ] && UV="$(which uv 2>/dev/null)"

if [ -z "$UV" ]; then
    # Offer to install uv automatically
    CHOICE=$(osascript -e '
        display dialog "PTT behöver \"uv\" för att köra.\n\nVill du installera det nu? (tar ~5 sekunder)" buttons {"Avbryt", "Installera"} default button "Installera" with title "PTT" with icon caution
        button returned of result
    ' 2>/dev/null)

    if [ "$CHOICE" = "Installera" ]; then
        curl -LsSf https://astral.sh/uv/install.sh | sh 2>/dev/null
        for p in "$HOME/.local/bin/uv" "$HOME/.cargo/bin/uv"; do
            [ -x "$p" ] && UV="$p" && break
        done
    fi

    if [ -z "$UV" ]; then
        osascript -e 'display alert "PTT" message "Kunde inte installera uv.\n\nInstallera manuellt:\nbrew install uv" as warning'
        exit 1
    fi
fi

export UV_HTTP_TIMEOUT=300
exec "$UV" run --script "$DIR/ptt.py"
